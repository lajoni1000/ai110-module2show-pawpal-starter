classDiagram
    class Owner {
        +String name
        +int available_time
        +List preferences
        +List~Pet~ pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Pet {
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +add_task(task)
        +remove_task(task)
        +get_tasks()
    }

    class Task {
        +String description
        +int duration
        +int priority
        +String task_type
        +bool completed
        +mark_complete()
    }

    class Scheduler {
        +Owner owner
        +generate_daily_plan()
        +sort_tasks()
        +filter_tasks()
    }

    Owner "1" *-- "many" Pet : owns
    Pet "1" *-- "many" Task : has
    Scheduler "1" --> "1" Owner : schedules for
